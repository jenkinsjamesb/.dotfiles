<!--
  This is a very simple config file with many options missing. For a complete
  set of options with comments, see docs/rc.xml.all
-->

<labwc_config>

  <theme>
    <name>Clearlooks-3.4</name>
    <cornerRadius>8</cornerRadius>
    <font name="sans" size="10" />
    <keepBorder>no</keepBorder>
  </theme>

  <keyboard>

    <default />

    <!-- Use a different terminal emulator -->
    <keybind key="W-Return">
      <action name="Execute" command="foot" />
    </keybind>

    <keybind key="W-l">
      <action name="Execute" command="swaylock" />
    </keybind>

    <keybind key="W-Space">
      <action name="ShowMenu" menu="root-menu" />
    </keybind>

    <keybind key="W-S-d">
      <action name="ToggleDecorations" />
    </keybind>

    <keybind key="W-S-f">
      <action name="ToggleFullscreen" />
    </keybind>

    <keybind key="W-S-q">
      <action name="Kill" />
    </keybind>
    
  </keyboard>

  <mouse>
    <default />

    <context name="All">
      <!-- Volume up on Super+ScrollUp -->
      <mousebind direction="W-Up" action="Scroll">
        <action name="Execute" command="pactl set-sink-volume \@DEFAULT_SINK@ +5%" />
      </mousebind>
   
      <!-- Volume down on Super+Scrolldown -->
      <mousebind direction="W-Down" action="Scroll">
        <action name="Execute" command="pactl set-sink-volume \@DEFAULT_SINK@ -5%" />
      </mousebind>
    </context>
  </mouse>

</labwc_config>
