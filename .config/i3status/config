# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
	output_format = i3bar
    colors = true
    color_good = "#aaffaa"
    color_degraded = "#ffffaa"
    color_bad = "#ffaaaa"
}

#order += "ipv6"
order += "wireless wlo1"
order += "ethernet enp42s0"
#order += "battery 0"
order += "disk /"
order += "memory"
#order += "cpu_usage"
order += "cpu_temperature 0"
order += "volume master"
order += "tztime local"

wireless wlo1 {
        format_up = "W:%quality at \"%essid\""
        format_down = "W: down"
}

ethernet enp42s0 {
        format_up = "E: %ip"
        format_down = "E: down"
}

#battery 0 {
#        format = "%status %percentage %remaining"
#        status_chr = "⚡ CHR"
#        status_bat = "🔋 BAT"
#        status_full = "🍺 FULL"
#        status_unk = "? UNK"
#        low_threshold = 25
#        threshold_type = "percentage"
#}

disk "/" {
	format = "💾 DSK %percentage_used %avail"
	format_below_threshold = "💾 LOW %percentage_used %avail"
	low_threshold = 25
	threshold_type = "percentage_free"
}

memory {
	format = "🐏 MEM %percentage_used %available"
	format_degraded = "🐏 LOW %percentage_used %available"
	threshold_degraded = "25%"
	threshold_critical = "10%"
}

#cpu_usage {
#	format = "CPU %usage"
#}

cpu_temperature 0 {
	format = "🌡️ TMP %degrees °C"
	format_above_threshold = "🔥 HOT %degrees °C"
	max_threshold = 65
}

volume master {
	format = "🔊 VOL %volume"
	format_muted = "🔇 MUTE"
}

